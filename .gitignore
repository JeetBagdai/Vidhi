# ============================================================
# Vidhi Platform - Root .gitignore
# ============================================================

# Python
__pycache__/
*.py[cod]
*$py.class
*.pyo
*.pyd
.Python
venv/
env/
ENV/
*.egg-info/
dist/
build/
.eggs/
*.egg

# Python test artifacts
.pytest_cache/
.coverage
htmlcov/

# Backend uploads (user files)
backend/uploads/

# Node / Next.js
frontend/node_modules/
frontend/.next/
frontend/out/
frontend/build/
frontend/.pnpm-debug.log*
frontend/npm-debug.log*
frontend/yarn-debug.log*
frontend/yarn-error.log*
frontend/*.tsbuildinfo
frontend/next-env.d.ts

# Environment variables - NEVER commit secrets
.env
.env.*
*.env
!.env.example

# OS / Editor
.DS_Store
Thumbs.db
.idea/
.vscode/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# Docker
*.log

# Certificates / Keys
*.pem
*.key
*.cert
